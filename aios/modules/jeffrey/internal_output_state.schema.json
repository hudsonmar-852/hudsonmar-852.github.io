{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jeffrey Derived Internal Output State",
  "type": "object",
  "additionalProperties": false,
  "required": ["energy_level", "warmth_level", "push_level", "humour_level", "mention_self"],
  "properties": {
    "energy_level": {"type": "integer", "minimum": 1, "maximum": 10},
    "warmth_level": {"type": "integer", "minimum": 1, "maximum": 10},
    "push_level": {"type": "integer", "minimum": 1, "maximum": 10},
    "humour_level": {"type": "integer", "minimum": 1, "maximum": 10},
    "message_length": {"enum": ["shorter", "normal"]},
    "mention_self": {"type": "boolean", "const": false},
    "source_private_note_injected": {"type": "boolean", "const": false}
  },
  "description": "Only derived, non-sensitive output controls may reach the generation prompt. Raw private notes must never be injected or published."
}
