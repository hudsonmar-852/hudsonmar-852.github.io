{
  "schema_version": "1.0.0",
  "module": "jeffrey_high_value_context_trigger",
  "status": "mvp",
  "source_tiers": {
    "tier_1_automatic_core": [
      "hko_weather_and_warnings",
      "government_practical_notices",
      "local_transport_and_southside_disruption",
      "curated_google_alert_results"
    ],
    "tier_2_scheduled_manual_input": [
      "the_southside_activities",
      "local_community_highlights"
    ],
    "tier_3_conditional_editorial_reference": [
      "chp_public_health_signals",
      "general_news_trends",
      "optional_cultural_calendar"
    ]
  },
  "gates": [
    "source_reliability",
    "safety_and_sensitivity",
    "southside_relevance",
    "client_usefulness",
    "jeffrey_voice_fit",
    "natural_conversation_potential"
  ],
  "scoring": {
    "source_reliability": 20,
    "client_usefulness": 25,
    "local_relevance": 20,
    "conversation_naturalness": 20,
    "jeffrey_brand_fit": 15,
    "minimum_total_to_generate": 70
  },
  "generation_rules": {
    "max_daily_suggestions": 3,
    "generate_only_for_affected_segments": true,
    "never_force_fitness_angle": true,
    "weather_is_context_not_mandatory_content": true,
    "one_message_one_purpose": true,
    "one_gentle_action_max": true,
    "human_approval_required": true
  },
  "excluded_from_core": [
    "lottery_calendar",
    "generic_viral_news_automation",
    "automatic_private_story_use"
  ]
}
