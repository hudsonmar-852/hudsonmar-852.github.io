{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hudsonmar-852.github.io/avataros/schemas/image-job.schema.json",
  "title": "AvatarOS Image Job",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "characterId", "objective", "render", "scene", "approval"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "characterId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "objective": {"type": "string", "minLength": 1, "maxLength": 240},
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "style", "aspectRatio", "imageCount", "format"],
      "properties": {
        "provider": {"const": "Grok Imagine"},
        "style": {"type": "string", "minLength": 1, "maxLength": 80},
        "aspectRatio": {"enum": ["1:1", "4:5", "9:16", "16:9"]},
        "imageCount": {"type": "integer", "minimum": 1, "maximum": 8},
        "format": {"enum": ["png", "jpg", "webp"]}
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["location", "camera", "lighting"],
      "properties": {
        "location": {"type": "string", "minLength": 1, "maxLength": 160},
        "camera": {"type": "string", "minLength": 1, "maxLength": 160},
        "lighting": {"type": "string", "minLength": 1, "maxLength": 160}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicSafe", "humanApprovalRequired"],
      "properties": {
        "publicSafe": {"type": "boolean"},
        "humanApprovalRequired": {"const": true}
      }
    }
  }
}
